{
  "name": "wikiguesser",
  "version": "1.0.0",
  "description": "WikiGuesser foundation built with Next.js, Prisma, and a Wikidata ingestion pipeline.",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "ingest:discover": "tsx src/scripts/discover.ts",
    "ingest:hydrate": "tsx src/scripts/hydrate.ts",
    "ingest:build-snapshot": "tsx src/scripts/build-snapshot.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.11",
    "@prisma/client": "^7.6.0",
    "next": "^16.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.1",
    "postcss": "^8.5.8",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  },
  "private": true
}
