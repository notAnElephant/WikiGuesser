{
  "name": "wikiguesser",
  "version": "1.0.0",
  "description": "WikiGuesser foundation built with Next.js, Prisma, and a Wikidata ingestion pipeline.",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "ingest:discover": "tsx src/scripts/discover.ts -- --category countries",
    "ingest:discover:cities": "tsx src/scripts/discover.ts -- --category cities",
    "ingest:hydrate": "tsx src/scripts/hydrate.ts -- --category countries",
    "ingest:hydrate:cities": "tsx src/scripts/hydrate.ts -- --category cities",
    "ingest:build-snapshot": "tsx src/scripts/build-snapshot.ts -- --category countries",
    "ingest:build-snapshot:cities": "tsx src/scripts/build-snapshot.ts -- --category cities",
    "ingest:build-snapshot:active": "tsx src/scripts/build-snapshot.ts -- --category countries,cities"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.11",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^0.542.0",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.0",
    "ws": "^8.20.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.1",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  },
  "private": true
}
